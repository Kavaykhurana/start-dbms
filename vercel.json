{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/handler?path=:path*"
    },
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/index.html",
      "destination": "/pages/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "/pages/index.html"
    },
    {
      "source": "/startups.html",
      "destination": "/pages/startups.html"
    },
    {
      "source": "/startups",
      "destination": "/pages/startups.html"
    },
    {
      "source": "/details.html",
      "destination": "/pages/details.html"
    },
    {
      "source": "/details",
      "destination": "/pages/details.html"
    },
    {
      "source": "/recommendations.html",
      "destination": "/pages/recommendations.html"
    },
    {
      "source": "/recommendations",
      "destination": "/pages/recommendations.html"
    },
    {
      "source": "/analytics.html",
      "destination": "/pages/analytics.html"
    },
    {
      "source": "/analytics",
      "destination": "/pages/analytics.html"
    },
    {
      "source": "/dbms.html",
      "destination": "/pages/dbms.html"
    },
    {
      "source": "/dbms",
      "destination": "/pages/dbms.html"
    }
  ]
}
